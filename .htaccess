<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to Laravel internals and secrets.
    RewriteRule ^laravel/\.env$ - [F,L,NC]
    RewriteRule ^laravel/(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/|$) - [F,L,NC]
    RewriteRule ^(composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|pnpm-lock\.yaml|vite\.config\.(js|ts)|webpack\.mix\.js)$ - [F,L,NC]
    RewriteRule ^laravel/(composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|pnpm-lock\.yaml|vite\.config\.(js|ts)|webpack\.mix\.js)$ - [F,L,NC]

    # Route all non-existing files/directories to root Laravel bootstrap.
    RewriteCond %{REQUEST_URI} !^/index\.php$
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>
